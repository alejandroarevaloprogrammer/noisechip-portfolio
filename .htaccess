
# ==================================================
# FORCE HTTPS + NO WWW
# ==================================================
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.noisechip\.com$ [NC]
RewriteRule ^(.*)$ https://noisechip.com/$1 [R=301,L]

# ==================================================
# OLD HTML PAGES -> GONE
# ==================================================
RedirectMatch 410 ^/(about|animations|characters|contact|fonts|games|gui|illustrations|mockups|tilesandbackgrounds|various|works)\.html$

# ==================================================
# OLD PROJECT PAGES -> GONE (HTML)
# ==================================================
RedirectMatch 410 ^/games/.*\.html$

# ==================================================
# OLD PROJECT PAGES -> GONE (SIN .html)
# ==================================================
RedirectMatch 410 ^/games/.*$

# ==================================================
# DEFAULT INDEX
# ==================================================
DirectoryIndex index.html

# ==================================================
# BASIC CACHE
# ==================================================
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# ==================================================
# BASIC SECURITY
# ==================================================
Options -Indexes
ServerSignature Off
